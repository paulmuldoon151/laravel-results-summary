{
    "name": "paulmuldoon/laravel-results-summary",
    "description": "A Blade component for displaying results summaries.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "illuminate/pagination": "^11.0 || ^12.0",
        "illuminate/support": "^11.0 || ^12.0",
        "illuminate/view": "^11.0 || ^12.0"
    },
    "require-dev": {
        "larastan/larastan": "^2.9 || ^3.0",
        "orchestra/testbench": "^9.0 || ^10.0",
        "pestphp/pest": "^2.0 || ^3.0"
    },
    "autoload": {
        "psr-4": {
            "PaulMuldoon\\ResultsSummary\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PaulMuldoon\\ResultsSummary\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "PaulMuldoon\\ResultsSummary\\ResultsSummaryServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
