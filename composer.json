{
    "name": "paulmuldoon/laravel-results-summary",
    "description": "A Blade component for displaying a summary of items in a collection",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "illuminate/pagination": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "illuminate/support": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "illuminate/view": "^10.0 || ^11.0 || ^12.0 || ^13.0"
    },
    "autoload": {
        "psr-4": {
            "PaulMuldoon\\ResultsSummary\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PaulMuldoon\\ResultsSummary\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "PaulMuldoon\\ResultsSummary\\ResultsSummaryServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
